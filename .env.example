# === 中转站 API 配置（必填） ===
# 你只需要填这 3 个

# 中转站接口地址（例：https://api.xxx.com/v1）
OPENAI_API_BASE=https://api.openai.com/v1

# 中转站给你的密钥
OPENAI_API_KEY=sk-your-api-key-here

# 你想用的模型名（中转站支持哪些就填哪些）
OPENAI_MODEL_NAME=gpt-4o-mini

# === RAG 知识库配置（可选，有默认值） ===
# Embedding 模型名（本地 sentence-transformers 模型）
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_BATCH_SIZE=8
EMBEDDING_BATCH_DELAY=0.3

# 离线模式（模型下载后设为 1 避免联网检查）
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# 数据加密（设为 true 启用）
RAG_ENCRYPTION_ENABLED=false